\n  (. shape :renderText canvas))"},{"id":"outline","script":"(do\n  (def! l (. shape :left))\n  (def! r (. shape :right))\n  (def! t (. shape :top))\n  (def! b (. shape :bottom))\n  (def! sa (. shape :getPropertyValue \"StartAngle\"))\n  (def! ca (. shape :getPropertyValue \"CentralAngle\"))\n  (def! v (. shape :getPropertyValue \"Thickness\"))\n  (def! thick (* (/ (. shape :width) 2) (/ v 100)))\n  (def! cx (/ (+ l r) 2))\n  (def! cy (/ (+ t b) 2))\n  (def! rx1 (/ (- r l) 2))\n  (def! ry1 (/ (- b t) 2))\n  (def! rx2 (- rx1 thick))\n  (def! ry2 (- ry1 thick))\n  (def! x1 (+ cx (* rx1 (cos (/ (* sa pi) 180)))))\n  (def! y1 (+ cy (* ry1 (sin (/ (* sa pi) 180)))))\n  (def! x2 (+ cx (* rx1 (cos (/ (* (+ sa ca) pi) 180)))))\n  (def! y2 (+ cy (* ry1 (sin (/ (* (+ sa ca) pi) 180)))))\n  (def! x3 (+ cx (* rx2 (cos (/ (* (+ sa ca) pi) 180)))))\n  (def! y3 (+ cy (* ry2 (sin (/ (* (+ sa ca) pi) 180)))))\n  (def! x4 (+ cx (* rx2 (cos (/ (* sa pi) 180)))))\n  (def! y4 (+ cy (* ry2 (sin (/ (* sa pi) 180)))))\n  (def! flag (if (<= ca 180) 0 1))\n  (def! seg (ceil (/ (+ rx1 ry1) 5)))\n  (def! arc1 (. geometry :pointsOnArc [cx cy] rx1 ry1 sa ca seg))\n  (def! arc2 (. geometry :pointsOnArc [cx cy] rx2 ry2 sa ca seg))\n  (concat arc1 (reverse arc2) [[x1 y1]]))"}],"corners":[24,24,24,24],"text":{"type":"doc","content":[{"type":"paragraph","attrs":{"textAlign":"center"}}]},"wordWrap":true},{"id":"bxs1HJds46My8GK095x2b","type":"Text","parent":"UaPy-YWmsYflbIw7UPulT","left":-350.53,"top":-557.02,"width":114,"height":20,"strokeWidth":2,"strokePattern":[0],"fillColor":"$transparent","roughness":1,"constraints":[{"id":"set-size","width":"text-min","height":"text"}],"text":{"type":"doc","content":[{"type":"paragraph","attrs":{"textAlign":"center"},"content":[{"type":"text","text":"Loading Data..."}]}]}},{"id":"zvLSh1vMlaxGTPxVH6Ps4","type":"Ellipse","parent":"UaPy-YWmsYflbIw7UPulT","name":"Badge","rotatable":false,"left":-350.53,"top":-557.02,"width":43.7,"height":42.66,"strokeWidth":2,"stro