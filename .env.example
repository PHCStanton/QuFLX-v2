# Application Configuration
APP_ENV=development
DEBUG=true

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Redis Configuration
# Default: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# AI Service Configuration
# ------------------------
# The API Key for your AI provider (e.g., OpenAI, Anthropic, or Internal)
AI_API_KEY=sk-your-api-key-here-xxxxxxxxxxxxxxxx

# Optional: The model to use (defaults to provider's default if not set)
AI_MODEL=gpt-4-turbo

# Optional: Custom API Base URL (if using a proxy or local LLM like Ollama)
# AI_BASE_URL=https://api.openai.com/v1
